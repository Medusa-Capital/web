# Google Analytics 4 Measurement ID
# Get this from: Google Analytics > Admin > Data Streams > Web > Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Notion Blog Sync
# 1. Create integration at: https://www.notion.so/my-integrations
# 2. Share your database with the integration (... > Connections > Add)
# 3. Copy the Database ID from the URL: notion.so/[workspace]/[DATABASE_ID]?v=...
NOTION_API_KEY=ntn_your_integration_token_here
NOTION_DATABASE_ID=your_database_id_here

# GA4 Data API (for scripts/sync-analytics.ts)
# Property ID: GA4 Admin > Property Settings (numeric ID)
GA4_PROPERTY_ID=123456789
# Optional: SA JSON key for local dev. In CI, Workload Identity Federation handles auth.
# Alternatively, run `gcloud auth application-default login` locally.
# GA4_CREDENTIALS_JSON={"type":"service_account",...}

# Supabase (for scripts/sync-analytics.ts)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
