# Google Analytics 4 Measurement ID
# Get this from: Google Analytics > Admin > Data Streams > Web > Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Notion Blog Sync
# 1. Create integration at: https://www.notion.so/my-integrations
# 2. Share your database with the integration (... > Connections > Add)
# 3. Copy the Database ID from the URL: notion.so/[workspace]/[DATABASE_ID]?v=...
NOTION_API_KEY=ntn_your_integration_token_here
NOTION_DATABASE_ID=your_database_id_here

# GA4 Data API (for scripts/sync-analytics.ts)
# Property ID: GA4 Admin > Property Settings (numeric ID)
GA4_PROPERTY_ID=123456789
# Optional: SA JSON key for local dev. In CI, Workload Identity Federation handles auth.
# Alternatively, run `gcloud auth application-default login` locally.
# GA4_CREDENTIALS_JSON={"type":"service_account",...}

# Airtable Webhooks (lead capture)
AIRTABLE_WEBHOOK_MASTERCLASS=https://hooks.airtable.com/workflows/v1/genericWebhook/...
AIRTABLE_WEBHOOK_PDF_5_ERRORES=https://hooks.airtable.com/workflows/v1/genericWebhook/...

# Supabase (for scripts/sync-analytics.ts)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Notion Analytics Sync (for scripts/sync-analytics-to-notion.ts)
# Page ID where the "Website Analytics — Weekly" database is created
NOTION_ANALYTICS_PARENT_PAGE_ID=

# ============================================================================
# Member Feedback (Phase 2-5) — auth, DB, email
# ============================================================================

# Public origin used for OAuth redirects, email links, and CSRF checks.
# Production: https://medusacapital.xyz
# Preview: the resolvable Vercel preview URL (find via `vercel inspect`)
NEXT_PUBLIC_APP_URL=https://medusacapital.xyz

# Iron-session cookie secret. ≥32 random bytes — `openssl rand -hex 32`.
# Doubles as the HKDF root for AES-GCM token encryption + unsubscribe HMAC.
SESSION_SECRET=

# Neon Postgres — pooled (DATABASE_URL) for serverless; unpooled for migrations.
DATABASE_URL=postgres://...neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgres://...neon.tech/neondb?sslmode=require

# Whop OAuth + API
# CLIENT_SECRET needs the oauth:token_exchange permission.
# API_KEY is company-scoped; needs memberships:read.
# COMPANY_ID is your biz_xxx.
# PRODUCT_ID is the prod_xxx the membership gate checks against.
WHOP_CLIENT_ID=app_xxxxxxxxxxxx
WHOP_CLIENT_SECRET=
WHOP_API_KEY=apik_xxxxxxxxxxxx
WHOP_COMPANY_ID=biz_xxxxxxxxxxxx
WHOP_MEDUSA_PRODUCT_ID=prod_xxxxxxxxxxxx

# Whop webhook signing secret — captured when registering /api/webhooks/whop
WHOP_WEBHOOK_SECRET=

# Resend (Phase 4 — email notifications)
# Domain in EMAIL_FROM must be verified in Resend (SPF/DKIM/DMARC).
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Medusa Capital <no-reply@mail.medusacapital.xyz>

# Sentry
SENTRY_DSN=https://xxx@sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# ============================================================================
# Argos dashboard
# ============================================================================
ARGOS_PASSWORD=
ROOT_DOMAIN=

# Market data provider keys (Argos)
COINGECKO_API_KEY=
COINALYZE_API_KEY=
COINGLASS_API_KEY=
POLYGON_API_KEY=
