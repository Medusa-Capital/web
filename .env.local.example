# Google Analytics 4 Measurement ID
# Get this from: Google Analytics > Admin > Data Streams > Web > Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Notion Blog Sync
# 1. Create integration at: https://www.notion.so/my-integrations
# 2. Share your database with the integration (... > Connections > Add)
# 3. Copy the Database ID from the URL: notion.so/[workspace]/[DATABASE_ID]?v=...
NOTION_API_KEY=ntn_your_integration_token_here
NOTION_DATABASE_ID=your_database_id_here

# GA4 Data API (for scripts/sync-analytics.ts)
# Property ID: GA4 Admin > Property Settings (numeric ID)
GA4_PROPERTY_ID=123456789
# Optional: SA JSON key for local dev. In CI, Workload Identity Federation handles auth.
# Alternatively, run `gcloud auth application-default login` locally.
# GA4_CREDENTIALS_JSON={"type":"service_account",...}

# Airtable Webhooks (lead capture)
AIRTABLE_WEBHOOK_MASTERCLASS=https://hooks.airtable.com/workflows/v1/genericWebhook/...
AIRTABLE_WEBHOOK_PDF_5_ERRORES=https://hooks.airtable.com/workflows/v1/genericWebhook/...

# Airtable REST API (for Calendly webhook → Airtable integration)
# Create a Personal Access Token at: https://airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write
# Access: CRM base (appOy27N5Wx2OdFX3)
AIRTABLE_API_TOKEN=pat...

# Calendly Webhook (booking → Airtable sync)
# The signing key used when registering the webhook subscription via Calendly API.
# Generate: openssl rand -hex 32
CALENDLY_WEBHOOK_SECRET=your_webhook_signing_key_here

# Supabase (for scripts/sync-analytics.ts)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Notion Analytics Sync (for scripts/sync-analytics-to-notion.ts)
# Page ID where the "Website Analytics — Weekly" database is created
NOTION_ANALYTICS_PARENT_PAGE_ID=
